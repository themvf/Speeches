+            "comments": int(totals.get("comments", 0) or 0),
+            "enriched_comments": int(totals.get("enriched_comments", 0) or 0),
+            "pending_review_comments": int(totals.get("pending_review_comments", 0) or 0),
+        },
+        "groups": groups,
+    }
